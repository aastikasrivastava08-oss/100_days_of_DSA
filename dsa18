 #include <stdio.h>

int main() {
    int n, k;

    // Input size
    scanf("%d", &n);

    int arr[n];

    // Input array
    for(int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    // Input k
    scanf("%d", &k);

    // Handle k > n
    k = k % n;

    // Reverse function logic inline

    // Step 1: Reverse entire array
    for(int i = 0; i < n/2; i++) {
        int temp = arr[i];
        arr[i] = arr[n - 1 - i];
        arr[n - 1 - i] = temp;
    }

    // Step 2: Reverse first k elements
    for(int i = 0; i < k/2; i++) {
        int temp = arr[i];
        arr[i] = arr[k - 1 - i];
        arr[k - 1 - i] = temp;
    }

    // Step 3: Reverse remaining elements
    for(int i = 0; i < (n - k)/2; i++) {
        int temp = arr[k + i];
        arr[k + i] = arr[n - 1 - i];
        arr[n - 1 - i] = temp;
    }

    // Output result
    for(int i = 0; i < n; i++) {
        printf("%d ", arr[i]);
    }

    return 0;
}