#include <stdio.h>

// Recursive function
int power(int a, int b) {
    if(b == 0)
        return 1;        // base case: a^0 = 1
    else
        return a * power(a, b - 1);
}

int main() {
    int a, b;

    // Input
    scanf("%d %d", &a, &b);

    // Output
    printf("%d", power(a, b));

    return 0;
}